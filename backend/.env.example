

# Database
DATABASE_URL=postgresql://footbot:footbot@localhost:5432/footbot
REDIS_URL=redis://localhost:6379

# LLM backend: "google" | "unsloth"
MODEL=google

# Google AI (Gemini)
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-flash

# Unsloth Studio (optional)
UNSLOTH_BASE_URL=http://127.0.0.1:8888
UNSLOTH_USERNAME=unsloth
UNSLOTH_PASSWORD=
UNSLOTH_MODEL=

# API-Football
API_FOOTBALL_KEY=your-api-football-key

# Content generation
AUTO_GENERATE=true
GENERATION_INTERVAL_MINUTES=30

# Seeder target DB for production runs
CHAOS_DB_URL=
